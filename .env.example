# =============================================================================
# Super Food - Template de Variaveis de Ambiente
# Copie para .env e preencha os valores
# =============================================================================

# ==================== OBRIGATORIO ====================

# Banco de dados
# Dev (SQLite): DATABASE_URL=sqlite:///./super_food.db
# Prod (PostgreSQL): DATABASE_URL=postgresql://user:senha@host:5432/superfood
DATABASE_URL=sqlite:///./super_food.db

# Chave secreta JWT (minimo 32 chars)
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_ALEATORIA

# Super Admin
SUPER_ADMIN_USER=superadmin
SUPER_ADMIN_PASS=TROQUE_ESTA_SENHA

# ==================== AMBIENTE ====================

# development | production
ENVIRONMENT=development

# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Debug mode
DEBUG=True

# ==================== MAPBOX ====================

MAPBOX_TOKEN=seu_token_mapbox_aqui

# ==================== REDIS (opcional em dev) ====================

# REDIS_URL=redis://localhost:6379/0

# ==================== STORAGE (imagens) ====================

# local | r2
STORAGE_BACKEND=local

# Cloudflare R2 (somente se STORAGE_BACKEND=r2)
# R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=superfood-uploads
# CDN_URL=https://cdn.superfood.com.br

# ==================== POSTGRESQL DOCKER ====================

# Usado pelo docker-compose
POSTGRES_DB=superfood
POSTGRES_USER=superfood
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_DO_BANCO

# ==================== EMAIL (futuro) ====================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# ==================== CLOUDFLARE (Caddy SSL) ====================

# CLOUDFLARE_API_TOKEN=
