def sidebar():
    """Exibe a sidebar com menu de navegação."""
    restaurante = st.session_state.restaurante
    
    with st.sidebar:
        st.markdown(f"### 🍔 {restaurante['nome']}")
        st.caption(f"📍 {restaurante.get('cidade', 'N/A')}")
        st.markdown("---")
        
        # Menu
        menu_options = {
            "📊 Dashboard": "dashboard",
            "🆕 Novo Pedido": "novo_pedido",
            "📋 Pedidos": "pedidos",
            "🛵 Motoboys": "motoboys",
            "🍔 Cardápio": "cardapio",
            "⚙️ Configurações": "configuracoes"
        }
        
        for label, page in menu_options.items():
            if st.button(label, key=f"menu_{page}", use_container_width=True):
                st.session_state.pagina = page
                st.rerun()
        
        st.markdown("---")
        
        # Info do plano
        st.caption(f"📋 Plano: {restaurante.get('plano', 'basico').upper()}")
        st.caption(f"🔑 Código Motoboy: {restaurante.get('codigo_acesso', 'N/A')}")
        
        st.markdown("---")
        
        if st.button("🚪 Sair", use_container_width=True):
            for key in list(st.session_state.keys()):
                del st.session_state[key]
            st.rerun()


# =============================================================================
# MAIN
# =============================================================================

def main():
    """Função principal do aplicativo."""
    # Inicializa estados
    if "logado" not in st.session_state:
        st.session_state.logado = False
    
    if "pagina" not in st.session_state:
        st.session_state.pagina = "dashboard"
    
    # Verifica login
    if not st.session_state.logado:
        tela_login()
        return
    
    # Exibe sidebar
    sidebar()
    
    # Renderiza página atual
    paginas = {
        "dashboard": pagina_dashboard,
        "novo_pedido": pagina_novo_pedido,
        "pedidos": pagina_pedidos,
        "motoboys": pagina_motoboys,
        "cardapio": pagina_cardapio,
        "configuracoes": pagina_configuracoes
    }
    
    pagina_atual = st.session_state.pagina
    if pagina_atual in paginas:
        paginas[pagina_atual]()
    else:
        pagina_dashboard()


if __name__ == "__main__":
    main()
