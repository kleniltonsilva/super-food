def calcular_e_exibir_taxa(
    endereco_cliente: str,
    coords_cliente: tuple,
    restaurante_data: dict,
    config_data: dict
) -> Dict[str, Any]:
    """
    Calcula e exibe a taxa de entrega em tempo real.
    
    Retorna dicionário com:
    - distancia_km: distância calculada
    - tempo_min: tempo estimado
    - taxa_entrega: valor da taxa
    - ganho_motoboy: valor para o motoboy
    - dentro_raio: se está dentro do raio de entrega
    """
    resultado = {
        "distancia_km": None,
        "tempo_min": None,
        "taxa_entrega": 0.0,
        "ganho_motoboy": 0.0,
        "dentro_raio": True,
        "erro": None
    }
    
    if not endereco_cliente:
        return resultado
    
    # Coordenadas do restaurante
    coords_restaurante = None
    if restaurante_data.get("latitude") and restaurante_data.get("longitude"):
        coords_restaurante = (
            restaurante_data["longitude"],
            restaurante_data["latitude"]
        )
    
    # Calcula distância
    endereco_restaurante = restaurante_data.get("endereco_completo", "")
    
    distancia, tempo = calcular_distancia_pedido(
        endereco_restaurante,
        endereco_cliente,
        coords_restaurante,
        coords_cliente
    )
    
    if distancia is None:
        resultado["erro"] = "Não foi possível calcular a distância"
        return resultado
    
    resultado["distancia_km"] = distancia
    resultado["tempo_min"] = tempo
    
    # Verifica raio de entrega
    raio_max = config_data.get("raio_maximo_entrega", 10.0)
    if distancia > raio_max:
        resultado["dentro_raio"] = False
        resultado["erro"] = f"Endereço fora do raio de entrega ({raio_max} km)"
        return resultado
    
    # Cria configuração
    config = ConfigEntrega(
        taxa_entrega_base=config_data.get("taxa_entrega_base", 5.0),
        km_base_entrega=config_data.get("km_base_entrega", 3.0),
        taxa_por_km_extra=config_data.get("taxa_por_km_extra", 2.0),
        valor_base_motoboy=config_data.get("valor_base_motoboy", 4.0),
        km_base_motoboy=config_data.get("km_base_motoboy", 3.0),
        valor_km_extra_motoboy=config_data.get("valor_km_extra_motoboy", 1.5)
    )
    
    # Calcula valores
    resultado["taxa_entrega"] = calcular_taxa_entrega(distancia, config)
    resultado["ganho_motoboy"] = calcular_ganho_motoboy(distancia, config)
    
    # Exibe o resultado
    if resultado["dentro_raio"]:
        st.markdown(f"""
        <div class="taxa-entrega-box">
            <p>📍 Distância: <strong>{distancia:.1f} km</strong> | ⏱️ Tempo estimado: <strong>{tempo:.0f} min</strong></p>
            <h2>Taxa de Entrega: {formatar_moeda(resultado['taxa_entrega'])}</h2>
            <p style="font-size: 0.9rem; opacity: 0.8;">Valor motoboy: {formatar_moeda(resultado['ganho_motoboy'])}</p>
        </div>
        """, unsafe_allow_html=True)
    else:
        st.error(f"⚠️ {resultado['erro']}")
    
    return resultado


