                taxa_simulada = taxa_base + ((dist_teste - km_base) * taxa_km_extra)
            
            st.markdown(f"**Taxa para {dist_teste} km:** {formatar_moeda(taxa_simulada)}")
            
            if st.form_submit_button("💾 Salvar Configurações"):
                with DatabaseSession() as db:
                    cfg = db.query(ConfigRestaurante).filter(
                        ConfigRestaurante.restaurante_id == restaurante_id
                    ).first()
                    
                    cfg.taxa_entrega_base = taxa_base
                    cfg.km_base_entrega = km_base
                    cfg.taxa_por_km_extra = taxa_km_extra
                    cfg.raio_maximo_entrega = raio_max
                    
                    db.commit()
                    st.success("Configurações de taxa salvas!")
    
    with tab3:
        st.markdown("### Configuração de Pagamento dos Motoboys")
        st.info("Defina quanto os motoboys ganham por entrega.")
        
        with st.form("config_pagamento_motoboy"):
            col1, col2 = st.columns(2)
            
            with col1:
                valor_base = st.number_input(
                    "Valor Base por Entrega (R$)",
                    value=float(config.get("valor_base_motoboy", 4.0)),
                    min_value=0.0,
                    step=0.50,
                    help="Valor pago para entregas até o km base"
                )
                
                km_base_motoboy = st.number_input(
                    "Km Base Motoboy",
                    value=float(config.get("km_base_motoboy", 3.0)),
                    min_value=0.0,
                    step=0.5,
                    help="Distância incluída no valor base"
                )
                
                valor_km_extra = st.number_input(
                    "Valor por Km Extra (R$)",
                    value=float(config.get("valor_km_extra_motoboy", 1.5)),
                    min_value=0.0,
                    step=0.25,
                    help="Valor adicional por km acima do km base"
                )
            
            with col2:
                taxa_diaria = st.number_input(
                    "Taxa Diária (R$)",
                    value=float(config.get("taxa_diaria_motoboy", 0.0)),
                    min_value=0.0,
                    step=5.0,
                    help="Valor fixo pago por dia (opcional)"
                )
                
                valor_lanche = st.number_input(
                    "Valor do Lanche (R$)",
                    value=float(config.get("valor_lanche_motoboy", 0.0)),
                    min_value=0.0,
                    step=5.0,
                    help="Valor pago para alimentação (opcional)"
                )
            
            # Simulação
            st.markdown("---")
            st.markdown("#### 🧮 Simulação de Ganho")
            
            dist_teste = st.slider("Distância de teste (km)", 0.5, 15.0, 5.0, 0.5, key="dist_motoboy")
            
            if dist_teste <= km_base_motoboy:
                ganho_simulado = valor_base
            else:
                ganho_simulado = valor_base + ((dist_teste - km_base_motoboy) * valor_km_extra)
            
            st.markdown(f"**Ganho para {dist_teste} km:** {formatar_moeda(ganho_simulado)}")
            st.caption(f"+ Diária: {formatar_moeda(taxa_diaria)} | + Lanche: {formatar_moeda(valor_lanche)}")
            
            if st.form_submit_button("💾 Salvar Configurações"):
                with DatabaseSession() as db:
                    cfg = db.query(ConfigRestaurante).filter(
                        ConfigRestaurante.restaurante_id == restaurante_id
                    ).first()
                    
                    cfg.valor_base_motoboy = valor_base
                    cfg.km_base_motoboy = km_base_motoboy
                    cfg.valor_km_extra_motoboy = valor_km_extra
                    cfg.taxa_diaria_motoboy = taxa_diaria
                    cfg.valor_lanche_motoboy = valor_lanche
                    
                    db.commit()
                    st.success("Configurações de pagamento salvas!")
    
    with tab4:
        st.markdown("### Formas de Pagamento Aceitas")
        
        with st.form("config_pagamentos"):
            col1, col2 = st.columns(2)
            
            with col1:
                aceita_dinheiro = st.checkbox("💵 Dinheiro", value=config.get("aceita_dinheiro", True))
                aceita_credito = st.checkbox("💳 Cartão de Crédito", value=config.get("aceita_cartao_credito", True))
                aceita_debito = st.checkbox("💳 Cartão de Débito", value=config.get("aceita_cartao_debito", True))
            
            with col2:
                aceita_pix = st.checkbox("📱 PIX", value=config.get("aceita_pix", True))
                chave_pix = st.text_input("Chave PIX", value=config.get("chave_pix", ""))
            
            if st.form_submit_button("💾 Salvar"):
                with DatabaseSession() as db:
                    cfg = db.query(ConfigRestaurante).filter(
                        ConfigRestaurante.restaurante_id == restaurante_id
                    ).first()
                    
                    cfg.aceita_dinheiro = aceita_dinheiro
                    cfg.aceita_cartao_credito = aceita_credito
                    cfg.aceita_cartao_debito = aceita_debito
                    cfg.aceita_pix = aceita_pix
                    cfg.chave_pix = chave_pix
                    
                    db.commit()
                    st.success("Formas de pagamento atualizadas!")


