def fazer_login(email: str, senha: str) -> Optional[Restaurante]:
    """Autentica um restaurante."""
    with DatabaseSession() as db:
        restaurante = db.query(Restaurante).filter(
            Restaurante.email == email,
            Restaurante.senha_hash == hash_password(senha),
            Restaurante.ativo == True
        ).first()
        
        if restaurante:
            # Atualiza último login
            restaurante.ultimo_login = datetime.utcnow()
            db.commit()
            
            # Retorna os dados necessários (evita detached instance)
            return {
                "id": restaurante.id,
                "nome": restaurante.nome,
                "email": restaurante.email,
                "telefone": restaurante.telefone,
                "endereco": restaurante.endereco,
                "numero": restaurante.numero,
                "bairro": restaurante.bairro,
                "cidade": restaurante.cidade,
                "estado": restaurante.estado,
                "cep": restaurante.cep,
                "latitude": restaurante.latitude,
                "longitude": restaurante.longitude,
                "codigo_acesso": restaurante.codigo_acesso,
                "plano": restaurante.plano.value if restaurante.plano else "basico",
                "endereco_completo": restaurante.endereco_completo
            }
    return None


