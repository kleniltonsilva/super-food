def autocomplete_endereco(
    label: str,
    key: str,
    cidade_restaurante: str,
    coords_restaurante: tuple = None
) -> Dict[str, Any]:
    """
    Componente de autocomplete de endereço usando Mapbox.
    
    Retorna dicionário com:
    - endereco: endereço selecionado
    - latitude: latitude
    - longitude: longitude
    """
    resultado = {
        "endereco": "",
        "latitude": None,
        "longitude": None
    }
    
    # Input do endereço
    endereco_input = st.text_input(
        label,
        key=f"{key}_input",
        placeholder=f"Digite o endereço em {cidade_restaurante}..."
    )
    
    if endereco_input and len(endereco_input) >= 3:
        # Busca sugestões do Mapbox
        # Adiciona a cidade para filtrar resultados
        query_com_cidade = f"{endereco_input}, {cidade_restaurante}, Brasil"
        
        sugestoes = geocode_autocomplete(
            query=query_com_cidade,
            proximity=coords_restaurante,
            limit=5
        )
        
        if sugestoes:
            # Filtra sugestões que contenham a cidade
            sugestoes_filtradas = [
                s for s in sugestoes 
                if cidade_restaurante.lower() in s.get("place_name", "").lower()
            ]
            
            # Se não houver filtradas, usa todas
            if not sugestoes_filtradas:
                sugestoes_filtradas = sugestoes
            
            # Mostra opções
            opcoes = ["Selecione um endereço..."] + [
                s.get("place_name", "") for s in sugestoes_filtradas
            ]
            
            selecionado = st.selectbox(
                "📍 Sugestões de endereço",
                opcoes,
                key=f"{key}_select"
            )
            
            if selecionado and selecionado != "Selecione um endereço...":
                # Encontra a sugestão selecionada
                for s in sugestoes_filtradas:
                    if s.get("place_name") == selecionado:
                        resultado["endereco"] = selecionado
                        if s.get("center"):
                            resultado["longitude"] = s["center"][0]
                            resultado["latitude"] = s["center"][1]
                        break
    
    return resultado


